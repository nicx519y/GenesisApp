#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_dir="$(cd "$script_dir/../.." && pwd)"
app_dir="$repo_dir/genesis_app"
dashboard_dir="$repo_dir/tools/location_chat_debug_dashboard"
env_file="${GENESIS_AGENT_CONTROL_ENV_FILE:-$app_dir/.agent-control.env}"

dashboard_port="${GENESIS_DASHBOARD_PORT:-${PORT:-17318}}"
skip_npm_install="${SKIP_NPM_INSTALL:-false}"
skip_adb_forward="${SKIP_ADB_FORWARD:-false}"
open_dashboard="${OPEN_DASHBOARD:-true}"
adb_bin="${ADB:-adb}"
dashboard_pid=""

usage() {
  cat <<'EOF'
Usage:
  tools/agent_cli/run-with-dashboard
  tools/agent_cli/run-with-dashboard -d <device-id>
  tools/agent_cli/run-with-dashboard --profile
  tools/agent_cli/run-with-dashboard --release

Starts the Flutter app with agent CLI + location-chat debug enabled, and starts
the local location chat dashboard in the background. Flutter build-mode flags
such as --profile and --release are forwarded to flutter run.

Environment:
  GENESIS_DASHBOARD_PORT      Dashboard port. Default: 17318.
  OPEN_DASHBOARD              Open dashboard in browser. Default: true.
  SKIP_NPM_INSTALL            Skip dashboard npm install. Default: false.
  SKIP_ADB_FORWARD            Skip adb forward. Default: false.
  ADB                         adb binary path. Default: adb.
EOF
}

dashboard_url() {
  printf 'http://127.0.0.1:%s/' "$dashboard_port"
}

dashboard_listener_pids() {
  lsof -nP -t -iTCP:"$dashboard_port" -sTCP:LISTEN 2>/dev/null || true
}

existing_dashboard_ready() {
  command -v curl >/dev/null 2>&1 || return 1
  curl -fsS --max-time 1 "$(dashboard_url)" 2>/dev/null |
    grep -q "Location Chat Debug"
}

ensure_dashboard_port_available() {
  if existing_dashboard_ready; then
    return 0
  fi

  local pids
  pids="$(dashboard_listener_pids)"
  if [[ -z "$pids" ]]; then
    return 0
  fi

  echo "Dashboard port $dashboard_port is already in use, but it does not look like the location chat dashboard." >&2
  echo "Listening processes:" >&2
  while IFS= read -r pid; do
    [[ -n "$pid" ]] || continue
    ps -p "$pid" -o pid=,command= >&2 || true
  done <<<"$pids"
  echo "Use GENESIS_DASHBOARD_PORT=<port> to choose another port, or run scripts/stop_agent_cli_dashboard.sh." >&2
  exit 1
}

ensure_adb_forward() {
  if [[ "$skip_adb_forward" == "true" ]]; then
    return 0
  fi
  if ! command -v "$adb_bin" >/dev/null 2>&1; then
    echo "adb is required but was not found in PATH." >&2
    echo "Set SKIP_ADB_FORWARD=true to start without USB forwarding." >&2
    exit 1
  fi
  echo "Forwarding Android agent_control port tcp:$agent_port -> tcp:$agent_port..."
  "$adb_bin" forward "tcp:$agent_port" "tcp:$agent_port"
}

cleanup() {
  local status=$?
  trap - EXIT
  if [[ -n "$dashboard_pid" ]] && kill -0 "$dashboard_pid" >/dev/null 2>&1; then
    echo "Stopping dashboard..."
    kill "$dashboard_pid" >/dev/null 2>&1 || true
    wait "$dashboard_pid" >/dev/null 2>&1 || true
  fi
  exit "$status"
}

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  usage
  exit 0
fi

if [[ ! -d "$dashboard_dir" ]]; then
  echo "Dashboard directory not found: $dashboard_dir" >&2
  exit 1
fi

if [[ ! -f "$env_file" ]]; then
  "$script_dir/ctl" init >/dev/null
fi

set -a
# shellcheck disable=SC1090
source "$env_file"
set +a

agent_host="${GENESIS_AGENT_CONTROL_HOST:-127.0.0.1}"
agent_port="${GENESIS_AGENT_CONTROL_PORT:-17317}"
agent_token="${GENESIS_AGENT_CONTROL_TOKEN:-}"

if [[ -z "$agent_token" ]]; then
  echo "Missing GENESIS_AGENT_CONTROL_TOKEN in $env_file" >&2
  exit 1
fi

trap cleanup EXIT
trap 'exit 130' INT
trap 'exit 143' TERM

ensure_adb_forward
ensure_dashboard_port_available

if existing_dashboard_ready; then
  echo "Reusing existing dashboard at $(dashboard_url)"
else
  (
    cd "$dashboard_dir"

    if ! command -v npm >/dev/null 2>&1; then
      echo "npm is required but was not found in PATH." >&2
      exit 1
    fi

    if [[ "$skip_npm_install" != "true" ]]; then
      echo "Installing dashboard dependencies..."
      npm install
    fi

    echo "Starting dashboard at $(dashboard_url)"
    exec env \
      PORT="$dashboard_port" \
      AGENT_CONTROL_URL="http://$agent_host:$agent_port" \
      GENESIS_AGENT_CONTROL_TOKEN="$agent_token" \
      npm start
  ) &
  dashboard_pid=$!

  sleep 1
  if ! kill -0 "$dashboard_pid" >/dev/null 2>&1; then
    wait "$dashboard_pid"
  fi
fi

dashboard_url="$(dashboard_url)"
echo "Dashboard: $dashboard_url"
echo "CLI: $script_dir/ctl app ping"

if [[ "$open_dashboard" == "true" ]] && command -v open >/dev/null 2>&1; then
  open "$dashboard_url" >/dev/null 2>&1 || true
fi

"$script_dir/run" \
  --dart-define=GENESIS_LOCATION_CHAT_DEBUG=true \
  "$@"
