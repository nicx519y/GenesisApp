#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
repo_dir="$(cd "$script_dir/../.." && pwd)"
app_dir="$repo_dir/genesis_app"
env_file="${GENESIS_AGENT_CONTROL_ENV_FILE:-$app_dir/.agent-control.env}"

usage() {
  cat <<'EOF'
Usage:
  tools/agent_cli/run
  tools/agent_cli/run -d <device-id>
  tools/agent_cli/run --release

This is a thin wrapper around flutter run. It automatically enables the
Genesis agent CLI port and reuses .agent-control.env.
EOF
}

generate_token() {
  if command -v openssl >/dev/null 2>&1; then
    openssl rand -base64 32 | tr -d '\n'
    return
  fi
  date "+%s%N" | shasum -a 256 | awk '{print $1}'
}

ensure_env_file() {
  if [[ -f "$env_file" ]]; then
    return
  fi
  local token
  token="$(generate_token)"
  cat >"$env_file" <<EOF
GENESIS_AGENT_CONTROL_HOST=127.0.0.1
GENESIS_AGENT_CONTROL_PORT=17317
GENESIS_AGENT_CONTROL_TOKEN=$token
EOF
  chmod 600 "$env_file"
}

if [[ "${1:-}" == "--help" || "${1:-}" == "-h" ]]; then
  usage
  exit 0
fi

ensure_env_file

set -a
# shellcheck disable=SC1090
source "$env_file"
set +a

port="${GENESIS_AGENT_CONTROL_PORT:-17317}"
token="${GENESIS_AGENT_CONTROL_TOKEN:-}"

if [[ -z "$token" ]]; then
  echo "Missing GENESIS_AGENT_CONTROL_TOKEN in $env_file" >&2
  exit 1
fi

if command -v adb >/dev/null 2>&1; then
  adb forward "tcp:$port" "tcp:$port" >/dev/null 2>&1 || true
fi

cd "$app_dir"
exec flutter run \
  --dart-define=GENESIS_AGENT_CONTROL_ENABLED=true \
  --dart-define=GENESIS_AGENT_CONTROL_TOKEN="$token" \
  --dart-define=GENESIS_AGENT_CONTROL_PORT="$port" \
  "$@"
